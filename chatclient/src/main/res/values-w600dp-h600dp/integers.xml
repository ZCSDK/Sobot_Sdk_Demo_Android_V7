<?xml version="1.0" encoding="utf-8"?>
<!--
  大屏专用档：折叠屏内屏 + 平板（w600dp + h600dp 组合限定符）
  pad 兜底
-->
<resources>

    <!--列表列数（横屏 1 列）-->
    <integer name="sobot_list_span_count">1</integer>

    <!--语言列表列数（Pad 竖屏 1 列）-->
    <integer name="sobot_languae_list_span_count">1</integer>

    <!--加号里 功能菜单区域 每页几行（Pad 竖屏）-->
    <integer name="sobot_plus_menu_line">2</integer>
    <!--加号里 功能菜单区域 每行几列（Pad 竖屏）-->
    <integer name="sobot_plus_menu_row">5</integer>
    <!--加号里边表情区域 一行显示几个表情（Pad 竖屏）-->
    <integer name="sobot_emoji_span_count">10</integer>

    <!--多轮模板（Template1 / 2 / 3 共用）选项列数（Pad / 折叠屏内屏 1 列）-->
    <integer name="sobot_robot_template_columns">1</integer>

    <!--多轮模板（Template1 / 3）每页行数（Pad / 折叠屏内屏 3 行）；每页总数 = rows × columns = 3 × 1 = 3-->
    <integer name="sobot_robot_template_rows">3</integer>

    <!--AiCard 商品列表列数（Pad / 折叠屏内屏 1 列；必须显式覆盖，否则 Android 会回落到 values-w600dp/ 的 2 列）-->
    <integer name="sobot_ai_card_span_count">1</integer>

</resources>
