<?xml version="1.0" encoding="utf-8"?>
<!--
  手机横屏专用档（w600dp，不含 h600dp 限定符）
  覆盖设备：宽 ≥ 600dp 且 高 < 600dp 的设备 — 主要是手机横屏
  典型场景：
    - 三星 S21 横屏（w=800, h=360）
    - Pixel 8 横屏（w=870, h=411）
    - 折叠屏外屏横屏（w=600~800, h=300~440）
  策略：
    - 横向间距加大（×1.25 让内容居中）
    - 宽度上限放大（屏宽充裕）
    - 纵向间距减小（×0.75，屏高紧张）
  注意：
    - 平板（含横屏）和折叠屏内屏 因 h ≥ 600dp 会命中 values-w600dp-h600dp/ 而非本档
    - 头像/圆角/字号等"视觉风格类"不在此档定义，回落到 values/ 基准
-->
<resources>

    <!-- ============== 横向加大（屏宽充裕，让内容居中） ============== -->

    <!--通用 距屏幕边 间距 -->
    <dimen name="sobot_Left_right_margin_edge">@dimen/sobot_layout_guide_margin</dimen>

    <!--左、右侧消息 距屏幕边 间距 -->
    <dimen name="sobot_msg_margin_edge">@dimen/sobot_layout_guide_margin</dimen>

    <!--消息气泡边界到屏幕边上的宽度（让气泡不撑满屏） -->
    <dimen name="sobot_chat_msg_boundary_to_empty_width">128dp</dimen>


    <!-- 通用头部 中间文字最大宽度 -->
    <dimen name="sobot_title_max_width">360dp</dimen>

    <!-- ============== 宽度放大（横向充裕） ============== -->

    <!--聊天界面 图片消息气泡中的 单独一张图片 最大 宽度 -->
    <dimen name="sobot_msg_picture_max_width">400dp</dimen>

    <!--聊天界面 图片消息气泡中的 单独一个视频 最大 宽度 -->
    <dimen name="sobot_msg_video_max_width">320dp</dimen>

    <!--聊天界面 引用消息气泡中的 单独一张图片 最大 宽度 -->
    <dimen name="sobot_appoint_msg_picture_max_width">100dp</dimen>

    <!--消息 (多轮等) 最大宽度 -->
    <dimen name="sobot_msg_content_max_width">400dp</dimen>

    <!--消息 (文章、文件、多轮等) 最小宽度 -->
    <dimen name="sobot_msg_min_width">137dp</dimen>

    <!-- ============== 纵向减小（屏高紧张，按设计稿 ×0.75） ============== -->

    <!--两个消息 上下间 间距（设计稿横屏 12dp） -->
    <dimen name="sobot_msg_top_bottom_margin">@dimen/sobot_form_vertical_gap</dimen>

    <!--两个消息 上下间 间距 1 分钟相邻同人 -->
    <dimen name="sobot_msg_top_bottom_small_margin">3dp</dimen>

    <!--左、右侧消息 气泡上下内间距 -->
    <dimen name="sobot_msg_top_bottom_padding_edge">8dp</dimen>

    <!--通告横幅 高度 -->
    <dimen name="sobot_announcement_height">32dp</dimen>

    <!--聊天界面 富文本消息气泡中的（知识库）图片 高度 -->
    <dimen name="sobot_rich_msg_picture_height_dp">150dp</dimen>
    <dimen name="sobot_rich_msg_picture_height_dp2">200dp</dimen>

    <!--聊天界面 图片消息气泡中的 单独一张图片 最大 高度 -->
    <dimen name="sobot_msg_picture_max_height">240dp</dimen>

    <!--聊天界面 图片消息气泡中的 单独一个视频 最大 高度 -->
    <dimen name="sobot_msg_video_max_height">180dp</dimen>

    <!--聊天界面 引用消息气泡中的 单独一张图片 最大 高度 -->
    <dimen name="sobot_appoint_msg_picture_max_height">60dp</dimen>

    <!--留言垂直间距 -->
    <dimen name="sobot_tiket_text_line_margin">12dp</dimen>

    <!--快捷菜单 距上方间距（横屏屏高紧张，调小） -->
    <dimen name="sobot_custom_menu_margin_top">8dp</dimen>
    <!--快捷菜单 距下方输入框间距 -->
    <dimen name="sobot_custom_menu_panel_margin">2dp</dimen>
    <!--聊天底部 输入框面板 上下内边距（横屏屏高紧张，调小） -->
    <dimen name="sobot_chat_bottom_panel_padding">4dp</dimen>

    <!-- ============== Figma 原子 token（Mobile Landscape 覆盖） ============== -->
    <!-- 仅覆盖与 values/ 基准不同的项；相同项回落到 values/ -->

    <!--栅格 边距 -->
    <dimen name="sobot_layout_guide_margin">20dp</dimen>
    <!--栅格 列间距 -->
    <dimen name="sobot_layout_guide_gutter">20dp</dimen>

    <!--表单 横向间距 -->
    <dimen name="sobot_form_horizontal_gap">20dp</dimen>
    <!--表单 纵向间距（横屏屏高紧张，调小） -->
    <dimen name="sobot_form_vertical_gap">12dp</dimen>

    <!--列表项 横向间距 -->
    <dimen name="sobot_list_item_horizontal_gap">12dp</dimen>
    <!--列表项 纵向间距 -->
    <dimen name="sobot_list_item_vertical_gap">12dp</dimen>

    <!--顶部导航 高度（横屏屏高紧张，调小） -->
    <dimen name="sobot_page_navigation_bar_height">44dp</dimen>
    <!--activity界面导航栏通用高度（不包含状态栏） -->
    <dimen name="sobot_common_titlebar_hight">@dimen/sobot_page_navigation_bar_height</dimen>
    <!--头部导航栏高度（不包含状态栏） -->
    <dimen name="sobot_header_titlebar_hight">@dimen/sobot_page_navigation_bar_height</dimen>
    <!--顶部导航 头像 -->
    <dimen name="sobot_page_navigation_avatar">28dp</dimen>
    <!--导航栏头像 宽高 -->
    <dimen name="sobot_header_face_width_heigth">@dimen/sobot_page_navigation_avatar</dimen>

    <!--消息 纵向间距 -->
    <dimen name="sobot_message_vertical_gap">8dp</dimen>
    <!--消息 气泡内容内边距 -->
    <dimen name="sobot_message_content_padding">8dp</dimen>

    <!--卡片 按钮高度 -->
    <dimen name="sobot_card_button_height">40dp</dimen>
    <!--卡片 内容内边距 -->
    <dimen name="sobot_card_content_padding">12dp</dimen>

    <!--卡片内 分割线下方间距（横屏调小） -->
    <dimen name="sobot_card_divider_margin_bottom">12dp</dimen>

    <!--消息气泡通用最大宽度（手机横屏 600dp）-->
    <dimen name="sobot_msg_max_width">600dp</dimen>
    <!--文件/文章/appoint 消息卡片屏宽百分比上限（手机横屏 屏宽 2/3）-->
    <item name="sobot_msg_card_max_width_percent" type="dimen" format="float">0.6</item>
    <!--切换语言气泡屏宽百分比主动撑宽（手机横屏 屏宽 5/6）-->
    <item name="sobot_msg_max_width_percent" type="dimen" format="float">0.8</item>
    <!--多轮气泡屏宽百分比主动撑宽（手机竖屏 0 = 不启用，自动适配；手机横屏/Pad 见各 values-w600dp 目录 0.91 = 屏宽 ）-->
    <item name="sobot_msg_template_max_width_percent" type="dimen" format="float">0.9</item>
    <!--点踩原因卡片、变量手机屏宽百分比主动撑宽（手机竖屏 0 = 不启用，自动适配；手机横屏/Pad 见各 values-w600dp 目录 0.68 = 屏宽 ）-->
    <item name="sobot_msg_cai_card_max_width_percent" type="dimen" format="float">0.68</item>
    <!--语言列表 item 间距（手机横屏 8dp）-->
    <dimen name="sobot_languae_list_item_gap">8dp</dimen>

    <!-- ============== 留言列表 / 模板 宽屏档（手机横屏） ============== -->

    <!--列表顶部间距 略加大 -->
    <dimen name="sobot_ticket_list_top_margin">12dp</dimen>
    <!--浮动按钮：屏高紧张上提；按钮拉宽更醒目 -->
    <dimen name="sobot_ticket_new_btn_bottom_margin">16dp</dimen>
    <dimen name="sobot_ticket_new_btn_padding_h">40dp</dimen>
    <!--按 figma 走查：手机横屏下"+留言"按钮总高 36dp（paddingV 8dp + text 行高 ~20dp）-->
    <dimen name="sobot_ticket_new_btn_padding_v">8dp</dimen>
    <dimen name="sobot_ticket_new_btn_min_width">200dp</dimen>
    <!--留言记录 item 内边距：按 figma 745:57961 横屏卡片，顶部/底部 20dp，水平 16dp -->
    <dimen name="sobot_tiket_item_padding_h">16dp</dimen>
    <dimen name="sobot_tiket_item_padding_top">20dp</dimen>
    <!--留言模板 item 顶部占位线高度：宽屏不需要 -->
    <dimen name="sobot_tiket_template_top_line_height">0dp</dimen>
    <!--留言模板 item 外边距：宽屏由 RecyclerView padding + ItemDecoration 控制 -->
    <dimen name="sobot_tiket_template_item_margin_h">0dp</dimen>
    <dimen name="sobot_tiket_template_item_margin_bottom">0dp</dimen>
    <!--留言模板 RecyclerView 底部额外 padding：手机横屏 elevation(16) + translationY(6) = 24dp，让最后一行阴影显示完整-->
    <dimen name="sobot_ticket_grid_template_shadow_padding">24dp</dimen>

    <!-- ============== 留言详情 + 回复弹窗 宽屏档（手机横屏） ============== -->

    <!--右侧固定面板：手机横屏 280dp-->
    <dimen name="sobot_ticket_side_panel_width">123dp</dimen>
    <!--输入框：横屏固定 96dp（用作 minHeight；高度由代码锁定）-->
    <dimen name="sobot_reply_edit_min_height">96dp</dimen>
    <!--附件按钮：横屏带边框样式略加大-->
    <dimen name="sobot_reply_file_btn_w">72dp</dimen>
    <dimen name="sobot_reply_file_btn_h">40dp</dimen>

    <!-- ============== 留言表单 + 完成态 宽屏档（手机横屏） ============== -->

    <!--表单：双列 + 列间距 20dp，行间距 12dp，左右内边距 24dp-->
    <dimen name="sobot_ticket_form_padding_h">24dp</dimen>
    <dimen name="sobot_ticket_form_h_space">20dp</dimen>
    <dimen name="sobot_ticket_form_v_space">12dp</dimen>
    <!--SobotInputView 字段间垂直间距（手机横屏，figma node 723:22735）：
         视觉总间距 = 本 dimen + label 高度(~20dp) + label→input 间距(8dp)。
         设 8dp 让总间距控制在 ~36dp，对应 figma 横屏视觉 -->
    <dimen name="sobot_form_field_top_margin">8dp</dimen>
    <!--完成态：左右父间距加宽避让安全区；按钮垂直居中无需底间距-->
    <dimen name="sobot_completed_actions_margin_h">60dp</dimen>
    <dimen name="sobot_completed_actions_margin_bottom">0dp</dimen>
    <!--横屏：完成按钮 top margin 不需要（左右排列）；按钮等分两列由代码切 weight=1-->
    <dimen name="sobot_completed_btn_top_margin">0dp</dimen>

    <!--加号里边表情区域 高度（手机横屏，popup 浮卡内的兜底值，运行时会被拉伸到 MATCH_PARENT）-->
    <dimen name="sobot_emoji_panel_height">140dp</dimen>

    <!--评价弹窗 横屏覆盖式 标题栏高度（与基准一致 44dp；显式列出便于后续单独调整）-->
    <dimen name="sobot_evaluate_title_height_land">44dp</dimen>

    <!--分词联想 popup（手机横屏 h≈360dp 可视区紧张，整体压扁；GridView padding=0 让 cell 全额吃 row_height，避免 item 被裁/内滚-->
    <dimen name="sobot_autocomplete_margin_top">4dp</dimen>
    <dimen name="sobot_autocomplete_margin_bottom">4dp</dimen>
    <dimen name="sobot_autocomplete_grid_padding">0dp</dimen>
    <!-- 32dp 略大于 item TextView 自然高度（14sp+7+7 padding≈31dp）；<31dp 会让 GridView 内部行高按 item 实际撑大，1 行视觉会异常高 -->
    <dimen name="sobot_autocomplete_row_height">31dp</dimen>
    <dimen name="sobot_autocomplete_anchor_gap">2dp</dimen>
    <!--大模型 答案有按钮时 行间距 -->
    <dimen name="sobot_text_line_spacing_aianswar_button">0dp</dimen>
    <!--富文本内联按钮（转人工 / 来源 等 sobotbutton）总高度（手机横屏 屏高紧张，-4dp 减小行高）-->
    <dimen name="sobot_rich_text_button_total_height">19.5dp</dimen>

    <!--AI Agent 底部按钮 上下内边距（手机横屏屏高紧张，调小 8dp）-->
    <dimen name="sobot_aiagent_button_item_padding_v">8dp</dimen>

</resources>
