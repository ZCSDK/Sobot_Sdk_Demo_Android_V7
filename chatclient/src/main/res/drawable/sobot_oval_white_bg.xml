<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <layer-list>
            <!-- 底层：原始背景 -->
            <item>
                <shape>
                    <solid android:color="@color/sobot_color_bg_third" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <!-- 上层：4% 黑色遮罩 -->
            <item>
                <shape>
                    <solid android:color="@color/sobot_press_color" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <shape>
            <solid android:color="@color/sobot_color_bg_third" />
            <stroke android:width="1dp" android:color="@color/sobot_color_line_divider_to_transparent_second" />
            <corners android:radius="8dp" />
        </shape>
    </item>

</selector>
