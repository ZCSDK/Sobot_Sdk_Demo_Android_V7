<?xml version="1.0" encoding="utf-8"?><!--快捷菜单 按钮 默认背景色-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@color/sobot_lable_nomal_bg_color" />
                    <stroke android:width="@dimen/sobot_line_height_dp" android:color="@color/sobot_lable_stroke_color" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item>
                <shape>
                    <solid android:color="@color/sobot_press_color" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape>
            <solid android:color="@color/sobot_lable_nomal_bg_color" />
            <stroke android:width="@dimen/sobot_line_height_dp" android:color="@color/sobot_lable_stroke_color" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
