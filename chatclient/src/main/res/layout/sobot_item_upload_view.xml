<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <TextView
        android:id="@+id/sobot_title_lable"
        style="@style/sobot_cur_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:clickable="false"
        android:focusable="false"
        android:text="" />

    <!--上传按钮-->

    <TextView
        android:id="@+id/sobot_btn_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/sobot_dialog_bg_line_4"
        android:clickable="true"
        android:drawableStart="@drawable/sobot_upload_file"
        android:drawablePadding="2dp"
        android:focusable="true"
        android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:text="@string/sobot_ticket_update_file"
        android:textColor="@color/sobot_color_text_first"
        android:textSize="@dimen/sobot_text_font_14" />

    <TextView
        android:id="@+id/sobot_file_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
        android:textColor="@color/sobot_dialog_input_error"
        android:textSize="@dimen/sobot_text_font_14"
        android:visibility="gone" />

    <TextView
        android:id="@+id/sobot_file_hite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
        android:textColor="@color/sobot_color_text_third"
        android:textSize="@dimen/sobot_text_font_14" />

    <!--    文件显示-->
    <LinearLayout
        android:id="@+id/sobot_layout_attachment_frame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/sobot_bg_gray_4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.sobot.chat.widget.SobotSectorProgressView
            android:id="@+id/sobot_file_thumbnail"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="8dp"
            android:scaleType="centerCrop"
            android:layout_gravity="center_vertical"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/sobot_file_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
                android:layout_marginEnd="16dp"
                android:textColor="@color/sobot_color_text_first"
                android:textSize="@dimen/sobot_text_font_14"
                android:singleLine="true" />

            <TextView
                android:id="@+id/sobot_file_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="17dp"
                android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
                android:visibility="gone"
                android:textColor="@color/sobot_color_text_third"
                android:textSize="@dimen/sobot_text_font_12" />
        </LinearLayout>

        <ImageView
            android:id="@+id/sobot_file_delete"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="8dp"
            android:src="@drawable/sobot_appoint_clear"
            android:visibility="visible" />


    </LinearLayout>
</LinearLayout>