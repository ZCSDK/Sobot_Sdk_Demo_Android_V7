<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <TextView
        android:id="@+id/sobot_title_lable"
        style="@style/sobot_cur_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:clickable="false"
        android:focusable="false"
        android:text="" />

    <!-- 虚线边框上传区域 -->
    <LinearLayout
        android:id="@+id/sobot_upload_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/sobot_upload_area_dashed_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- 上传按钮 -->
        <TextView
            android:id="@+id/sobot_btn_file"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/sobot_dialog_bg_line_6"
            android:clickable="true"
            android:drawableStart="@drawable/sobot_upload_file"
            android:drawablePadding="6dp"
            android:focusable="true"
            android:gravity="center"
            android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/sobot_ticket_update_file"
            android:textColor="@color/sobot_color_text_first"
            android:textSize="@dimen/sobot_text_font_14" />

        <!-- 提示文字 -->
        <TextView
            android:id="@+id/sobot_file_hite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
            android:textColor="@color/sobot_color_text_third"
            android:textSize="@dimen/sobot_text_font_12" />

    </LinearLayout>

    <!-- 已上传文件列表（横向滚动，每项由 addPicView 动态添加） -->
    <HorizontalScrollView
        android:id="@+id/sobot_file_list_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/sobot_layout_file_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <TextView
        android:id="@+id/sobot_file_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
        android:textColor="@color/sobot_dialog_input_error"
        android:textSize="@dimen/sobot_text_font_14"
        android:visibility="gone" />

</LinearLayout>
