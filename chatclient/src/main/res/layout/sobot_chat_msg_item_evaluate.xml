<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sobot_real_ll_content"
    style="@style/sobot_msg_top_bottom_style"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/sobot_reminde_time_Text"
        style="@style/sobot_center_remind_time" />


    <com.sobot.chat.widget.SobotMaxSizeLinearLayout
        style="@style/sobot_msg_content_ll_hollow_bg_no_padding_style"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:orientation="vertical"
        app:sobot_max_width_percent="@dimen/sobot_msg_card_max_width_percent"
        android:padding="24dp">

        <TextView
            android:id="@+id/sobot_tv_star_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:textColor="@color/sobot_color_text_first"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/sobot_readiogroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/sobot_ll_ok_robot"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/sobot_evaluate_ding_circle_bg"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/iv_solved"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/sobot_evaluate_btn_yes_selector" />

                </LinearLayout>

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:id="@+id/sobot_ll_no_robot"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/sobot_evaluate_cai_circle_bg"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/iv_no_solve"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/sobot_evaluate_btn_no_selector" />

                </LinearLayout>
            </LinearLayout>

            <View
                android:id="@+id/sobot_ratingBar_split_view"
                android:layout_width="match_parent"
                android:layout_height="0.6dp"
                android:layout_marginTop="24dp"
                android:background="@color/sobot_color_line_divider_2"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <!--五星-->
                <com.sobot.chat.widget.SobotFiveStarsLayout
                    android:id="@+id/sobot_ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="13dp"
                    android:visibility="visible" />
                <!--10分-->
                <LinearLayout
                    android:id="@+id/sobot_ten_root_ll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_horizontal"
                    android:minWidth="292dp"
                    android:orientation="vertical">


                    <com.sobot.chat.widget.SobotTenRatingLayout
                        android:id="@+id/sobot_ten_rating_ll"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                    </com.sobot.chat.widget.SobotTenRatingLayout>
                </LinearLayout>
                <!--二级-->
                <LinearLayout
                    android:id="@+id/ll_2_type"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="4dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/sobot_btn_satisfied"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/iv_satisfied"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/sobot_satisfie_btn" />

                    </LinearLayout>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="0.6dp" />

                    <LinearLayout
                        android:id="@+id/sobot_btn_dissatisfied"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="bottom|center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/iv_dissatisfied"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/sobot_dissatisfied_btn" />

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/sobot_ratingBar_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/sobot_ten_evaluate_select"
                    android:textSize="@dimen/sobot_text_font_12" />


                <LinearLayout
                    android:id="@+id/sobot_hide_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/sobot_text_other_problem"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:textColor="@color/sobot_color_text_first"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <com.sobot.chat.widget.SobotAntoLineLayout
                        android:id="@+id/sobot_evaluate_lable_autoline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:sobot_fillMode="1"
                        app:sobot_horizontalGap="8dp"
                        app:sobot_verticalGap="8dp" />

                </LinearLayout>

                <!--备注-->
                <com.sobot.chat.widget.SobotEditTextLayout
                    android:id="@+id/setl_submit_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="24dp"
                    android:visibility="gone">

                    <com.sobot.chat.widget.SobotEditText
                        android:id="@+id/sobot_add_content"
                        android:layout_width="match_parent"
                        android:textCursorDrawable="@drawable/sobot_cursor_drawable"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/sobot_bg_dialog_input"
                        android:enabled="true"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
                        android:lines="4"
                        android:maxLength="200"
                        android:padding="10dp"
                        android:scrollbars="none"
                        android:textColor="@color/sobot_color_text_first"
                        android:textColorHint="@color/sobot_color_text_third"
                        android:textSize="@dimen/sobot_text_font_14" />
                </com.sobot.chat.widget.SobotEditTextLayout>
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/sobot_submit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/sobot_bg_theme_color_28dp"
            android:gravity="center"
            android:minHeight="40dp"
            android:paddingStart="15dp"
            android:paddingTop="10dp"
            android:paddingEnd="15dp"
            android:paddingBottom="10dp"
            android:textColor="@color/sobot_color_white"
            android:textSize="@dimen/sobot_text_font_14"
            android:visibility="visible" />
    </com.sobot.chat.widget.SobotMaxSizeLinearLayout>

</LinearLayout>