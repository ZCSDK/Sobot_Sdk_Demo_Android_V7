<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sobot_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sobot_color_transparent"
    android:gravity="bottom"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sobot_color_bg_first"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <com.sobot.chat.widget.SobotEditText
            android:id="@+id/sobot_reply_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/sobot_bg_line2_4"
            android:enabled="true"
            android:gravity="top"
            android:hint="@string/sobot_please_input"
            android:inputType="textMultiLine"
            android:maxLength="200"
            android:minHeight="112dp"
            android:minLines="3"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp"
            android:scrollbars="vertical"
            android:textColor="@color/sobot_color_text_first"
            android:textColorHint="@color/sobot_color_text_third"
            android:textCursorDrawable="@drawable/sobot_cursor_drawable"
            android:textSize="@dimen/sobot_text_font_14" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/sobot_reply_msg_pic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:listSelector="@android:color/transparent"
            android:visibility="gone" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/sobot_btn_file"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:paddingStart="4dp"
                android:paddingTop="8dp"
                android:paddingEnd="4dp"
                android:src="@drawable/sobot_upload_file" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/sobot_btn_submit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/sobot_btn_bg_16"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp"
                android:text="@string/sobot_button_send"
                android:textColor="@color/sobot_color_white"
                android:textSize="@dimen/sobot_text_font_14" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>