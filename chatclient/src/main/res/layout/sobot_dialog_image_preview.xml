<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BF000000">

    <!-- ViewPager: full size -->
    <androidx.viewpager.widget.ViewPager
        android:id="@+id/sobot_preview_viewpager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top: page indicator "1/4" -->
    <TextView
        android:id="@+id/sobot_preview_indicator"
        android:layout_width="46dp"
        android:layout_height="28dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="20dp"
        android:background="@drawable/sobot_preview_indicator_bg"
        android:gravity="center"
        android:textColor="@color/sobot_color_white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Bottom: download button (暂隐藏) -->
    <TextView
        android:id="@+id/sobot_preview_btn_download"
        android:layout_width="100dp"
        android:layout_height="36dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="60dp"
        android:background="@drawable/sobot_preview_pill_bg"
        android:gravity="center"
        android:text="@string/sobot_file_download"
        android:textColor="@color/sobot_color_white"
        android:textSize="15sp"
        android:visibility="gone" />

</FrameLayout>
