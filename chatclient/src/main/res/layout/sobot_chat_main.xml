<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sobot_color_chat_bg"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/iv_message_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <RelativeLayout
        android:id="@+id/sobot_chat_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!--底部包裹层：恒为 VISIBLE，避免内部 sobot_bar_bottom 被 GONE 时 RelativeLayout 锚链断裂导致 RV 高度坍缩-->
        <LinearLayout
            android:id="@+id/ll_bottom_wrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical">

            <!--语音转文字提示 + 快捷菜单：从 sobot_layout_chat_bottom 迁移到此处，避免在底部 LinearLayout 内挤压输入框线框。
                包一层 LinearLayout 保留原 visibility 切换时的间距行为（两者全 gone 时 0 间距）-->
            <LinearLayout
                android:id="@+id/ll_chat_above_bottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!--语音转文字提示-->
                <TextView
                    android:id="@+id/send_voice_robot_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/sobot_colot_audio_to_text_tip"
                    android:breakStrategy="simple"
                    android:gravity="center"
                    android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
                    android:paddingStart="@dimen/sobot_msg_margin_edge"
                    android:paddingTop="8dp"
                    android:paddingEnd="@dimen/sobot_msg_margin_edge"
                    android:paddingBottom="8dp"
                    android:textColor="@color/sobot_color_wenzi_white_to_gray"
                    android:textSize="@dimen/sobot_text_font_12"
                    android:visibility="gone" />

                <!--快捷菜单-->
                <HorizontalScrollView
                    android:id="@+id/sobot_custom_menu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/sobot_custom_menu_margin_top"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/sobot_custom_menu_linearlayout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <!--底部栏-->
            <include
                android:id="@+id/sobot_bar_bottom"
                layout="@layout/sobot_layout_chat_bottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!--通告内容布局-->
        <RelativeLayout
            android:id="@+id/rl_announcement"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sobot_announcement_height"
            android:background="@drawable/sobot_announcmnt_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/sobot_msg_margin_edge"
            android:paddingEnd="@dimen/sobot_msg_margin_edge"
            android:visibility="gone">

            <!--通告标题-->
            <TextView
                android:id="@+id/tv_announcement_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/iv_announcement_right_icon"
                android:ellipsize="marquee"
                android:includeFontPadding="false"
                android:layout_centerVertical="true"
                android:marqueeRepeatLimit="marquee_forever"
                android:singleLine="true"
                android:textColor="@color/sobot_announcement_title_color"
                android:textSize="@dimen/sobot_text_font_12" />

            <!--通告右边的箭头-->
            <ImageView
                android:id="@+id/iv_announcement_right_icon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="6dp"
                android:src="@drawable/sobot_icon_tonggao_arrow"
                android:visibility="gone" />
        </RelativeLayout>
        <!--消息列表-->
        <com.sobot.chat.widget.refresh.layout.SobotRefreshLayout
            android:id="@+id/sobot_srv_message"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/ll_bottom_wrapper"
            android:layout_below="@+id/rl_announcement">

            <com.sobot.chat.widget.refresh.SobotClassicsHeader
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:sobotSrlFinishDuration="0" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/sobot_rv_message"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </com.sobot.chat.widget.refresh.layout.SobotRefreshLayout>
        <!-- 切换机器人按钮：竖屏贴底（ll_bottom_wrapper 上方 20dp）、横屏贴顶（sobot_chat_main 顶部 20dp），
             默认按横屏样式摆放，竖屏由 SobotChatFragment#applySwitchRobotLayoutByOrientation 切换。
             注：anchor 必须用 ll_bottom_wrapper（sobot_chat_main 直接子），不能用嵌套的 ll_chat_above_bottom -->
        <com.sobot.chat.widget.attach.SobotRobotAttachLinearlayout
            android:id="@+id/ll_switch_robot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/sobot_swith_robot_bg"
            android:elevation="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:outlineSpotShadowColor="@color/sobot_color_shadow_second"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp"
            android:translationY="6dp"
            android:visibility="visible">

            <ImageView
                android:id="@+id/iv_switch_robot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:scaleType="fitCenter"
                android:src="@drawable/sobot_icon_switch_robot" />

            <TextView
                android:id="@+id/tv_switch_robot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
                android:paddingStart="10dp"
                android:paddingEnd="0dp"
                android:text="@string/sobot_switch_business"
                android:textColor="@color/sobot_color_text_first"
                android:textSize="@dimen/sobot_text_font_12" />
        </com.sobot.chat.widget.attach.SobotRobotAttachLinearlayout>
        <!--底部 新消息提醒-->
        <FrameLayout
            android:id="@+id/ll_newmsg"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_above="@+id/ll_bottom_wrapper"
            android:layout_centerHorizontal="true"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:layoutDirection="ltr"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/iv_newmsg"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@drawable/sobot_icon_newmsg" />

            <TextView
                android:id="@+id/tv_newmsg"
                android:layout_width="wrap_content"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/sobot_round_red"
                android:gravity="center"
                android:minWidth="16dp"
                android:paddingStart="3dp"
                android:paddingEnd="4dp"
                android:textColor="@color/sobot_color_white"
                android:textSize="@dimen/sobot_text_font_12" />
        </FrameLayout>
        <!-- 语音功能布局 -->
        <LinearLayout
            android:id="@+id/ll_sound_recording"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="67dp"
            android:background="@drawable/sobot_recording_hint_bg"
            android:gravity="center_horizontal|bottom"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="40dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_recording_countdown_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_horizontal"
                android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="@color/sobot_color_text_third"
                android:textSize="@dimen/sobot_text_font_12"
                android:visibility="invisible" />

            <FrameLayout
                android:id="@+id/fl_sound_recording_animation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <!-- 结束语音图片 -->
                <ImageView
                    android:id="@+id/iv_sound_recording_cancle"
                    android:layout_width="129dp"
                    android:layout_height="12dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/sobot_voiceTimeLong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
                    android:textColor="@color/sobot_color_text_first"
                    android:textSize="@dimen/sobot_text_font_14" />

                <ImageView
                    android:id="@+id/iv_sound_recording_in_progress"
                    android:layout_width="129dp"
                    android:layout_height="12dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_recording_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_horizontal"
                android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="@color/sobot_color_chat_bottom_record_sound_hint"
                android:textSize="@dimen/sobot_text_font_14" />
        </LinearLayout>

        <!--开始新会话卡片顶部阴影：紧贴 bar_bottom 上方，定义在 sobot_chat_main 末尾保证 z 顺序高于 RecyclerView，盖在消息上-->
        <View
            android:id="@+id/sobot_v_restart_talk_shadow"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_above="@id/ll_bottom_wrapper"
            android:background="@drawable/sobot_top_divider_shadow"
            android:visibility="gone" />
    </RelativeLayout>

    <!--顶部 未读消息提示-->
    <FrameLayout
        android:id="@+id/ll_notReadInfo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="30dp"
        android:layoutDirection="ltr"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_not_read"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/sobot_icon_unread" />

        <TextView
            android:id="@+id/notReadInfo"
            android:layout_width="wrap_content"
            android:layout_height="16dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="3dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/sobot_round_red"
            android:gravity="center"
            android:minWidth="16dp"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingBottom="2dp"
            android:textColor="@color/sobot_color_white"
            android:textSize="@dimen/sobot_text_font_12" />
    </FrameLayout>

    <!-- loading布局 -->
    <include
        android:id="@+id/sobot_welcome"
        layout="@layout/sobot_layout_chat_loading"
        android:visibility="visible" />
</FrameLayout>