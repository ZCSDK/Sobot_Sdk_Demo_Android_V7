<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sobot_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sobot_color_transparent"
    android:gravity="bottom"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sobot_color_bg_first"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingTop="10dp">

        <!-- 输入框：竖屏 wrap_content + minHeight；横屏由 Java 锁定固定高度 -->
        <com.sobot.chat.widget.SobotEditText
            android:id="@+id/sobot_reply_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/sobot_bg_line2_4"
            android:enabled="true"
            android:gravity="top"
            android:hint="@string/sobot_please_input"
            android:inputType="textMultiLine"
            android:maxLength="200"
            android:minHeight="@dimen/sobot_reply_edit_min_height"
            android:minLines="3"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp"
            android:scrollbars="vertical"
            android:textColor="@color/sobot_color_text_first"
            android:textColorHint="@color/sobot_color_text_third"
            android:textCursorDrawable="@drawable/sobot_cursor_drawable"
            android:textSize="@dimen/sobot_text_font_14" />

        <!-- 底部栏：附件按钮 + 取消按钮 + 发送按钮 -->
        <LinearLayout
            android:id="@+id/ll_sobot_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/sobot_reply_bottom_margin_top"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/sobot_btn_file"
                android:layout_width="@dimen/sobot_reply_file_btn_w"
                android:layout_height="@dimen/sobot_reply_file_btn_h"
                android:layout_marginStart="20dp"
                android:paddingStart="24dp"
                android:paddingTop="8dp"
                android:paddingEnd="24dp"
                android:src="@drawable/sobot_upload_file" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- 新增：取消按钮（宽度按翻译文案自适应） -->
            <TextView
                android:id="@+id/sobot_btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/sobot_reply_btn_gap"
                android:background="@drawable/sobot_btn_bg_help_center"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp"
                android:text="@string/sobot_btn_cancle"
                android:textColor="@color/sobot_color_text_first"
                android:textSize="@dimen/sobot_text_font_14" />

            <TextView
                android:id="@+id/sobot_btn_submit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:background="@drawable/sobot_bg_theme_color_16dp"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp"
                android:text="@string/sobot_button_send"
                android:textColor="@color/sobot_color_white"
                android:textSize="@dimen/sobot_text_font_14" />
        </LinearLayout>

        <!-- 附件 RecyclerView：移到底部按钮栏下方 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/sobot_reply_msg_pic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="12dp"
            android:listSelector="@android:color/transparent"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
