<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/sobot_dialog_title_bg"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/ll_title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        tools:ignore="UseCompoundDrawables">

        <!-- 左侧占位：与右侧关闭按钮(36dp) + marginEnd(12dp) 等宽，保证标题视觉居中 -->
        <Space
            android:layout_width="48dp"
            android:layout_height="wrap_content" />

        <!-- 标题 -->
        <TextView
            android:id="@+id/sobot_tv_title"
            style="@style/sobot_dialog_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center" />

        <ImageView
            android:id="@+id/iv_closes"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/sobot_button_bg"
            android:contentDescription="@string/sobot_colse"
            android:padding="8dp"
            android:scaleType="fitXY"
            android:src="@drawable/sobot_icon_dialog_close" />
    </LinearLayout>

    <View
        android:id="@+id/v_line_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/sobot_line_height_dp"
        android:background="@color/sobot_dialog_line" />
</LinearLayout>
