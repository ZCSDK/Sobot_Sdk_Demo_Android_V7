<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/sobot_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="bottom"
    android:orientation="vertical">

    <com.sobot.chat.widget.SobotMHLinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/sobot_dialog_title_bg"
        android:orientation="vertical"
        android:paddingBottom="40dp"
        app:sobot_mhv_HeightRatio="0.9">

        <!-- 横屏标题栏：title(左) + 搜索框(中) + close(右) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/sobot_dialog_title_bg"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/ll_title_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="13"
                tools:ignore="UseCompoundDrawables">

                <!-- 标题 -->
                <TextView
                    android:id="@+id/sobot_tv_title"
                    style="@style/sobot_dialog_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:gravity="center_vertical"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <!-- 搜索框 -->
                <LinearLayout
                    android:id="@+id/ll_search"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="6"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/sobot_search_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/sobot_search_input_bg"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/et_search"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:gravity="center_vertical"
                            android:hint="@string/sobot_please_input"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:lines="1"
                            android:paddingStart="12dp"
                            android:paddingTop="9dp"
                            android:paddingEnd="2dp"
                            android:paddingBottom="9dp"
                            android:textColor="@color/sobot_color_text_first"
                            android:textColorHint="@color/sobot_color_text_third"
                            android:textCursorDrawable="@drawable/sobot_cursor_drawable"
                            android:textSize="@dimen/sobot_text_font_14" />

                        <ImageView
                            android:id="@+id/sobot_iv_clear"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="3dp"
                            android:padding="9dp"
                            android:src="@drawable/sobot_cur_input_clear"
                            android:visibility="gone" />

                        <ImageView
                            android:id="@+id/sobot_iv_search"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="3dp"
                            android:padding="9dp"
                            android:src="@drawable/sobot_cur_search" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_closes"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/sobot_button_bg"
                    android:contentDescription="@string/sobot_colse"
                    android:padding="8dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/sobot_icon_dialog_close" />
            </LinearLayout>

            <View
                android:id="@+id/v_line_title"
                android:layout_width="match_parent"
                android:layout_height="@dimen/sobot_line_height_dp"
                android:background="@color/sobot_dialog_line" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@color/sobot_dialog_bg_color"
            android:orientation="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="20dp"
                android:layout_weight="1"
                android:minHeight="320dp"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tv_nodata"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="20dp"
                android:layout_weight="1"
                android:minHeight="320dp"
                android:gravity="center"
                android:lineSpacingExtra="@dimen/sobot_text_line_spacing_extra"
                android:text="@string/sobot_no_data_string"
                android:textColor="@color/sobot_color_text_third"
                android:textSize="@dimen/sobot_text_font_14"
                android:visibility="gone" />

        </LinearLayout>
    </com.sobot.chat.widget.SobotMHLinearLayout>
</LinearLayout>
