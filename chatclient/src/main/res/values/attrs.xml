<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--圆形-->
    <attr name="sobot_round_as_circle" format="boolean" />
    <!--全部圆角半径-->
    <attr name="sobot_round_corner" format="integer|dimension" />
    <!--针对各个角的半径-->
    <attr name="sobot_round_corner_top_left" format="integer|dimension" />
    <attr name="sobot_round_corner_top_right" format="integer|dimension" />
    <attr name="sobot_round_corner_bottom_left" format="integer|dimension" />
    <attr name="sobot_round_corner_bottom_right" format="integer|dimension" />

    <!--描边颜色／半径-->
    <attr name="sobot_stroke_color" format="color|reference" />
    <attr name="sobot_stroke_width" format="integer|dimension" />

    <!-- 是否剪裁 RCLayout 的背景 -->
    <attr name="sobot_clip_background" format="boolean" />

    <!--真正用于解析的属性-->
    <declare-styleable name="SobotRCAttrs">
        <attr name="sobot_round_as_circle" />
        <attr name="sobot_round_corner" />
        <attr name="sobot_round_corner_top_left" />
        <attr name="sobot_round_corner_top_right" />
        <attr name="sobot_round_corner_bottom_left" />
        <attr name="sobot_round_corner_bottom_right" />
        <attr name="sobot_stroke_color" />
        <attr name="sobot_stroke_width" />
        <attr name="sobot_clip_background" />
    </declare-styleable>

    <!--假体：用于提示-->
    <declare-styleable name="sobot_RCRelativeLayout">
        <attr name="sobot_round_as_circle" />
        <attr name="sobot_round_corner" />
        <attr name="sobot_round_corner_top_left" />
        <attr name="sobot_round_corner_top_right" />
        <attr name="sobot_round_corner_bottom_left" />
        <attr name="sobot_round_corner_bottom_right" />
        <attr name="sobot_stroke_color" />
        <attr name="sobot_stroke_width" />
        <attr name="sobot_clip_background" />
    </declare-styleable>

    <declare-styleable name="sobot_RCImageView">
        <attr name="sobot_round_as_circle" />
        <attr name="sobot_round_corner" />
        <attr name="sobot_round_corner_top_left" />
        <attr name="sobot_round_corner_top_right" />
        <attr name="sobot_round_corner_bottom_left" />
        <attr name="sobot_round_corner_bottom_right" />
        <attr name="sobot_stroke_color" />
        <attr name="sobot_stroke_width" />
        <attr name="sobot_clip_background" />
    </declare-styleable>

    <declare-styleable name="sobot_MHLinearLayout">
        <attr name="sobot_mhv_HeightRatio" format="float" />
        <attr name="sobot_mhv_HeightDimen" format="dimension" />
        <attr name="sobot_mhH_HeightRatio" format="float" />
        <attr name="sobot_mhH_HeightDimen" format="dimension" />
    </declare-styleable>

    <declare-styleable name="sobot_ExpandableTextView">
        <attr name="sobot_maxCollapsedLines" format="integer" />
        <attr name="sobot_ExpandStrResId" format="reference" />
        <attr name="sobot_CollapseStrResId" format="reference" />
    </declare-styleable>

    <declare-styleable name="sobot_GifView2">
        <attr name="sobot_gif" format="reference" />
        <attr name="sobot_paused" format="boolean" />
    </declare-styleable>

    <declare-styleable name="sobot_autoWrapLineLayout">
        <attr name="sobot_verticalGap" format="dimension" />
        <attr name="sobot_horizontalGap" format="dimension" />
        <attr name="sobot_fillMode" format="integer" />
    </declare-styleable>

    <declare-styleable name="sobot_SubsamplingScaleImageView">
        <attr name="sobot_src" format="reference" />
        <attr name="sobot_assetName" format="string" />
        <attr name="sobot_panEnabled" format="boolean" />
        <attr name="sobot_zoomEnabled" format="boolean" />
        <attr name="sobot_quickScaleEnabled" format="boolean" />
        <attr name="sobot_tileBackgroundColor" format="color" />
    </declare-styleable>

    <!--KPSwitchPanelLayout -->
    <declare-styleable name="SobotKPSwitchPanelLayout">
        <attr name="sobot_ignore_recommend_height" format="boolean" />
    </declare-styleable>

    <!--控件最大宽高-->
    <declare-styleable name="sobot_maxsize_layout">
        <!-- 最大宽（默认"上限"语义：父可用宽超过才限，保留原 mode；配合 sobot_fill_to_max_width=true 切换为"主动撑宽"） -->
        <attr name="sobot_max_width" format="dimension" />
        <attr name="sobot_max_height" format="dimension" />
        <!-- 宽度占屏宽百分比（0~1，0 = 不启用）；默认"上限"语义（屏宽×百分比作为上限，超过才限，保留原 mode）；配合 sobot_fill_to_max_width=true 切换为"主动撑宽"；与 sobot_max_width 同时存在取较小 -->
        <attr name="sobot_max_width_percent" format="float" />
        <!-- 配合 sobot_max_width / sobot_max_width_percent 使用：true=按 EXACTLY 主动撑宽到目标值，让 match_parent 子 View 跟随撑开；false（默认）=上限语义 -->
        <attr name="sobot_fill_to_max_width" format="boolean" />
    </declare-styleable>

    <!--拖拽吸附控件-->
    <declare-styleable name="sobot_attach_layout">
        <attr name="customIsAttach" format="boolean" />
        <attr name="customIsDrag" format="boolean" />
    </declare-styleable>
    <!--带有加载进度条的图片控件-->
    <declare-styleable name="sobot_progress_imageview">
        <attr name="image_max_width" format="dimension" />
        <attr name="image_max_height" format="dimension" />
        <attr name="image_min_width" format="dimension" />
        <attr name="image_min_height" format="dimension" />
        <!--图片宽-->
        <attr name="image_width" format="dimension" />
        <!--图片高-->
        <attr name="image_height" format="dimension" />
        <!--控件变化时 是否带有系统动画效果-->
        <attr name="image_layout_change_animate" format="boolean" />
        <!--预加载时是否显示加载控件-->
        <attr name="image_is_show_progressbar" format="boolean" />
        <!--预加载时背景色-->
        <attr name="image_bg" format="color" />
        <!--预加载时占位图-->
        <attr name="image_loading_drawable" format="reference" />
    </declare-styleable>

    <!--  带标题、输入框、错误提示  -->
    <declare-styleable name="SobotInputView">
        <!-- 是否隐藏标题-->
        <attr name="sobot_hint_title" format="boolean" />
        <!-- 输入类型：single_line、many_lines、select-->
        <attr name="sobot_input_type" format="string" />
        <!-- 标题-->
        <attr name="sobot_input_title" format="string" />
        <!-- 输入提示-->
        <attr name="sobot_input_hint" format="string" />
        <!-- 输入的默认值-->
        <attr name="sobot_input_value" format="string" />
        <!-- 输入框输入内容的类型：邮箱、电话、数字-->
        <attr name="sobot_input_view_type" format="string" />
        <!-- 选择框右边的小图标,时间、日历、箭头等小图标-->
        <attr name="sobot_input_select_icon" format="reference" />
        <!-- 输入框内容长度限制-->
        <attr name="sobot_input_length_limit" format="integer" />
    </declare-styleable>

    <declare-styleable name="SobotLoadingView">
        <attr name="sobot_background_color" format="color" />
        <attr name="sobot_progress_color" format="color" />
        <attr name="sobot_strokeWidth" format="dimension" />
    </declare-styleable>
</resources>