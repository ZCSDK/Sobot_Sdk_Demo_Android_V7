<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.sobot.chat">
    <!-- 访问权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- To handle the reselection within the app on Android 14 (API level 34) or higher -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />
    <!-- Devices running Android 13 (API level 33) or higher -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Devices running Android 12L (API level 32) or lower  -->
    <!-- 安全：API 33+ 已用细粒度 READ_MEDIA_IMAGES / READ_MEDIA_VIDEO 替代，仅在低版本声明 -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <supports-screens
        android:anyDensity="true"
        android:largeScreens="true"
        android:normalScreens="true"
        android:resizeable="true"
        android:smallScreens="true"
        android:xlargeScreens="true" />

    <application>
        <!-- 安全：所有 Activity 显式声明 android:exported="false"。
             SDK 内部 Activity 不接受外部 Intent 调用，避免未来误加 intent-filter 时暴露 (CWE-16)。
             备份/网络安全策略由宿主 App 在自身 Manifest 中声明（android:allowBackup
             / android:fullBackupContent / android:networkSecurityConfig）。 -->
        <activity
            android:name=".activity.SobotPrivacyAgreementActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|touchscreen|navigation|locale|fontScale|uiMode|screenLayout|smallestScreenSize"
